# --- Fitatu credentials (required) ---
FITATU_USERNAME=you@example.com
FITATU_PASSWORD=change-me
# Pull the api-secret header value from network requests in the Fitatu web app.
FITATU_API_SECRET=change-me

# --- MCP inbound auth (required) ---
# Generate with: openssl rand -hex 32
MCP_API_KEY=change-me

# --- Storage ---
# Inside the container; the compose volume `fitatu_data` mounts on /data.
FITATU_DB_FILE=/data/fitatu_nutrition.db

# --- Server tuning ---
LOG_LEVEL=INFO
MCP_ENABLE_DNS_REBINDING_PROTECTION=false
# Comma-separated host:port allowlist used when DNS rebinding protection is on.
# MCP_ALLOWED_HOSTS=localhost,localhost:*,fitatu-mcp,fitatu-mcp:*
# How long today's cache is treated as fresh before re-syncing on read tools.
FITATU_TODAY_TTL_SECONDS=300

# --- Write tools ---
# Optional Fitatu cluster overrides. Reads use the locale cluster (pl-pl); writes use the canonical app cluster (www).
# Do NOT include "/api" suffix — the client appends it as needed.
# FITATU_BASE_URL_READ=https://pl-pl.fitatu.com
# FITATU_BASE_URL_WRITE=https://www.fitatu.com
# Set to true to enable destructive tools (delete_custom_product, delete_meal_item).
# Default is false so accidental LLM-triggered deletes cannot land.
FITATU_ALLOW_DELETE=false

# --- compose.yml knobs ---
# Override which image compose pulls; leave default to build locally.
# FITATU_MCP_IMAGE=ghcr.io/pawelharacz/fitatu-mcp:latest
FITATU_MCP_PORT=8000

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Warsaw
# Generate with: openssl rand -hex 32 — REQUIRED to keep stored credentials safe across restarts.
N8N_ENCRYPTION_KEY=change-me
# Set to true if you front n8n with HTTPS.
N8N_SECURE_COOKIE=false
